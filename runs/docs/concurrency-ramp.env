# Per-scenario values for: docs concurrency-ramp.
# Source this before `envsubst < testrun.yaml | kubectl apply -f -`.
# The credentials Secret injects the OIDC token-fetch vars:
#   KEYCLOAK_TOKEN_URL, KEYCLOAK_CLIENT_ID (e.g. admin-cli), KEYCLOAK_USERNAME, KEYCLOAK_PASSWORD
#   (KEYCLOAK_CLIENT_SECRET only for a confidential client).
export LOAD_TEST_NAME=docs-concurrency-ramp
export PARALLELISM=1
export SCRIPTS_CONFIGMAP=docs-scenarios
export SCRIPT_FILE=concurrency-ramp.ts
export CREDENTIALS_SECRET=loadtest-docs-credentials

# Runner resources. Small request/response payloads; CPU headroom for request scheduling at 100 VUs.
export RUNNER_CPU_REQUEST=300m
export RUNNER_CPU_LIMIT=1
export RUNNER_MEMORY_REQUEST=256Mi
export RUNNER_MEMORY_LIMIT=2Gi

# Load profile for the ramp→plateau (make sweep overrides TARGET_VUS per level; `make run
# vus= ramp= hold=` overrides one-off). The ramp re-auths on 401, so RAMP_UP+HOLD may exceed
# the realm's access-token lifespan (journey/seed remain TTL-bound).
# Representative results need the seeded dataset — `make seed app=docs` first.
export TARGET_VUS=25
export RAMP_UP=30s
export HOLD=2m
