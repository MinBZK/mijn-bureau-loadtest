# Per-scenario values for: docs journey (realistic user mix over a seeded dataset).
# Source this before `envsubst < testrun.yaml | kubectl apply -f -`.
# The credentials Secret injects the OIDC token-fetch vars (see runs/docs/concurrency-ramp.env).
export LOAD_TEST_NAME=docs-journey
export PARALLELISM=1
export SCRIPTS_CONFIGMAP=docs-scenarios
export SCRIPT_FILE=journey.ts
export CREDENTIALS_SECRET=loadtest-docs-credentials

# Runner resources. Small payloads; bump memory (and/or PARALLELISM) for high TARGET_VUS sweeps.
export RUNNER_CPU_REQUEST=300m
export RUNNER_CPU_LIMIT=1
export RUNNER_MEMORY_REQUEST=256Mi
export RUNNER_MEMORY_LIMIT=2Gi

# Load profile. `make sweep` overrides TARGET_VUS per level to find the breaking point.
export TARGET_VUS=25
export RAMP_UP=30s
export HOLD=2m
