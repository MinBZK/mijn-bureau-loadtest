# Per-scenario values for: docs seed/unseed (one-time dataset provisioning for the journey).
# `make seed app=docs` runs SEED_MODE=create; `make unseed app=docs` overrides SEED_MODE=delete.
export LOAD_TEST_NAME=docs-seed
export PARALLELISM=1
export SCRIPTS_CONFIGMAP=docs-scenarios
export SCRIPT_FILE=seed.ts
export CREDENTIALS_SECRET=loadtest-docs-credentials

# Runner resources. One VU issuing sequential creates/deletes.
export RUNNER_CPU_REQUEST=200m
export RUNNER_CPU_LIMIT=1
export RUNNER_MEMORY_REQUEST=128Mi
export RUNNER_MEMORY_LIMIT=256Mi

# Seed knobs.
export SEED_MODE=create
export SEED_DOC_COUNT=300
