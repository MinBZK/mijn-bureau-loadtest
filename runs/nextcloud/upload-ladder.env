# Per-scenario values for: Nextcloud upload-ladder.
# Source this before `envsubst < testrun.yaml | kubectl apply -f -`.
export LOAD_TEST_NAME=nextcloud-upload-ladder
export PARALLELISM=1
export SCRIPTS_CONFIGMAP=nextcloud-scenarios
export SCRIPT_FILE=upload-ladder.ts
export CREDENTIALS_SECRET=loadtest-nextcloud-credentials

# Runner resources. Upload-ladder is single-VU; modest is enough, but bump
# the memory limit if you raise the top of the size ladder past 128 MB.
export RUNNER_CPU_REQUEST=200m
export RUNNER_CPU_LIMIT=1
export RUNNER_MEMORY_REQUEST=256Mi
export RUNNER_MEMORY_LIMIT=768Mi
