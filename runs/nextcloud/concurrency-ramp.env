# Per-scenario values for: Nextcloud concurrency-ramp.
# Source this before `envsubst < testrun.yaml | kubectl apply -f -`.
export LOAD_TEST_NAME=nextcloud-concurrency-ramp
export PARALLELISM=1
export SCRIPTS_CONFIGMAP=nextcloud-scenarios
export SCRIPT_FILE=concurrency-ramp.ts
export CREDENTIALS_SECRET=loadtest-nextcloud-credentials

# Runner resources. Concurrency-ramp drives up to 100 concurrent VUs each
# holding a 1 MB buffer; the runner needs more headroom than upload-ladder.
export RUNNER_CPU_REQUEST=500m
export RUNNER_CPU_LIMIT=2
export RUNNER_MEMORY_REQUEST=512Mi
export RUNNER_MEMORY_LIMIT=1Gi
