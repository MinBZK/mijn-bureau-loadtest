# Per-scenario values for: conversations conversation-ramp (LLM streaming path).
# Source this before `envsubst < testrun.yaml | kubectl apply -f -`.
# The credentials Secret injects the OIDC token-fetch vars (see runs/conversations/concurrency-ramp.env).
export LOAD_TEST_NAME=conversations-conversation-ramp
export PARALLELISM=1
export SCRIPTS_CONFIGMAP=conversations-scenarios
export SCRIPT_FILE=conversation-ramp.ts
export CREDENTIALS_SECRET=loadtest-conversations-credentials

# Runner resources. Few VUs, each holding one streaming response.
export RUNNER_CPU_REQUEST=200m
export RUNNER_CPU_LIMIT=1
export RUNNER_MEMORY_REQUEST=128Mi
export RUNNER_MEMORY_LIMIT=512Mi

# Load profile. Completions take seconds to minutes — sweep small levels ("1 2 4 8 16").
# Keep RAMP_UP+HOLD under the realm's access-token lifespan: the token is fetched once in setup().
export TARGET_VUS=4
export RAMP_UP=30s
export HOLD=2m
