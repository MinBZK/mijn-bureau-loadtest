# Per-scenario values for: conversations concurrency-ramp.
# Source this before `envsubst < testrun.yaml | kubectl apply -f -`.
# The credentials Secret injects the OIDC token-fetch vars:
#   KEYCLOAK_TOKEN_URL, KEYCLOAK_CLIENT_ID (e.g. admin-cli), KEYCLOAK_USERNAME, KEYCLOAK_PASSWORD
#   (KEYCLOAK_CLIENT_SECRET only for a confidential client).
export LOAD_TEST_NAME=conversations-concurrency-ramp
export PARALLELISM=1
export SCRIPTS_CONFIGMAP=conversations-scenarios
export SCRIPT_FILE=concurrency-ramp.ts
export CREDENTIALS_SECRET=loadtest-conversations-credentials

# Runner resources. Small request/response payloads; CPU headroom for request scheduling at 100 VUs.
export RUNNER_CPU_REQUEST=300m
export RUNNER_CPU_LIMIT=2
export RUNNER_MEMORY_REQUEST=256Mi
export RUNNER_MEMORY_LIMIT=512Mi

# Load profile for the ramp→plateau (make sweep overrides TARGET_VUS per level).
export TARGET_VUS=25
export RAMP_UP=30s
export HOLD=2m
export RAMP_DOWN=30s
