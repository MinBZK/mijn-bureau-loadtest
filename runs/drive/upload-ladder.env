# Per-scenario values for: Drive upload-ladder (bandwidth baseline; in-cluster only).
# Source this before `envsubst < testrun.yaml | kubectl apply -f -`.
# The credentials Secret injects the OIDC token-fetch vars (same as the Drive list scenario):
#   KEYCLOAK_TOKEN_URL, KEYCLOAK_CLIENT_ID, KEYCLOAK_USERNAME, KEYCLOAK_PASSWORD
export LOAD_TEST_NAME=drive-upload-ladder
export PARALLELISM=1
export SCRIPTS_CONFIGMAP=drive-scenarios
export SCRIPT_FILE=upload-ladder.ts
export CREDENTIALS_SECRET=loadtest-drive-credentials

# Runner resources. Single VU, but it buffers one file at a time — give memory headroom for the
# top of the size ladder (64 MB here).
export RUNNER_CPU_REQUEST=200m
export RUNNER_CPU_LIMIT=1
export RUNNER_MEMORY_REQUEST=256Mi
export RUNNER_MEMORY_LIMIT=768Mi

# upload-ladder uses a shared-iterations executor; these plateau knobs are unused but kept so the
# TestRun template substitutes cleanly.
export TARGET_VUS=1
export RAMP_UP=0s
export HOLD=0s
export RAMP_DOWN=0s
