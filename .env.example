# Copy to .env.local (gitignored) and source before running tests.

# TARGET_URL is the endpoint of the app under test — set it per app before each run.
# e.g. Nextcloud:  https://files.demo.mijnbureau.gov.nl
#      Keycloak:   https://keycloak.demo.mijnbureau.gov.nl
export TARGET_URL=https://files.demo.mijnbureau.gov.nl

# Remote-write endpoint. OpenShift's bundled prometheus-k8s doesn't accept writes;
# point at Mimir/Thanos/Grafana Cloud or a Prometheus with --web.enable-remote-write-receiver.
export PROMETHEUS_RW_URL=https://your-prometheus.example/api/v1/write
